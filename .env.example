APP_NAME="SamgyHann 199 POS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=samgyhann
# DB_USERNAME=root
# DB_PASSWORD=

CACHE_STORE=file
# Do NOT change to 'database' — this app has no cache table. Use 'file' or 'array'.
QUEUE_CONNECTION=sync

SESSION_DRIVER=file
SESSION_LIFETIME=10080
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
